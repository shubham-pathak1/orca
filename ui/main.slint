import { AppState, SongRow, SongRowData, ArtistRow, ArtistRowData, AlbumRow, AlbumRowData, PlaylistRow, QueueRow } from "global.slint";
export { AppState, SongRow, SongRowData, ArtistRow, ArtistRowData, AlbumRow, AlbumRowData, PlaylistRow, QueueRow }

import { ScrollView } from "std-widgets.slint";
import { Sidebar } from "modules/sidebar.slint";
import { PlayerBar } from "modules/player_bar.slint";
import { BottomPlayer } from "modules/bottom_player.slint";
import { QueuePanel } from "modules/queue_panel.slint";
import { Header } from "modules/header.slint";
import { FullPlayerOverlay } from "modules/full_player.slint";
import { SongListView } from "views/song_list.slint";
import { GridViews } from "views/grids.slint";
import { PlaylistsView } from "views/playlists.slint";
import { SettingsView } from "views/settings.slint";
import "fonts/PlusJakartaSans-Regular.ttf";
import "fonts/PlusJakartaSans-Medium.ttf";
import "fonts/PlusJakartaSans-SemiBold.ttf";
import "fonts/PlusJakartaSans-Bold.ttf";

export component MainWindow inherits Window {
    title: "Orca";
    icon: @image-url("../public/orca_logo.png");
    preferred-width: 1280px;
    preferred-height: 820px;
    min-width: 1040px;
    min-height: 700px;
    no-frame: true; // FRAMELESS EVOLUTION
    background: #080808;
    default-font-family: "Plus Jakarta Sans, system-ui, sans-serif";

    forward-focus: focus-scope;

    focus-scope := FocusScope {
        VerticalLayout {
            // ── Custom Title Bar (Frameless Support) ──
            if (!AppState.is-fullscreen) : Rectangle {
                height: 32px;
                HorizontalLayout {
                    padding-left: 14px; padding-right: 0px;
                    
                    // Draggable Area (Main Handle)
                    TouchArea {
                        horizontal-stretch: 1;
                        pointer-event(event) => {
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                AppState.drag-window();
                            }
                        }
                    }

                    // Window Controls
                    HorizontalLayout {
                        spacing: 0px;
                        Rectangle {
                            width: 48px; height: 32px; background: min_t.has-hover ? #ffffff10 : #00000000;
                            // Minimize Stroke
                            Rectangle {
                                width: 10px; height: 1px; background: #ffffff;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                opacity: min_t.has-hover ? 1.0 : 0.6;
                            }
                            min_t := TouchArea { clicked => { AppState.minimize-window(); } }
                        }
                        Rectangle {
                            width: 48px; height: 32px; background: max_t.has-hover ? #ffffff10 : #00000000;
                            // Maximize Square
                            Rectangle {
                                width: 9px; height: 9px; 
                                border-width: 1px; border-color: #ffffff;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                opacity: max_t.has-hover ? 1.0 : 0.6;
                            }
                            max_t := TouchArea { clicked => { AppState.maximize-window(); } }
                        }
                        Rectangle {
                            width: 48px; height: 32px; background: close_t.has-hover ? #e81123 : #00000000;
                            Image {
                                source: AppState.icon-x;
                                width: 14px; height: 14px;
                                colorize: #ffffff;
                                opacity: close_t.has-hover ? 1.0 : 0.6;
                                vertical-alignment: center; horizontal-alignment: center;
                            }
                            close_t := TouchArea { clicked => { AppState.close-window(); } }
                        }
                    }
                }
            }

            HorizontalLayout {
                Sidebar {}
    
                Rectangle {
                    horizontal-stretch: 1;
                    VerticalLayout {
                        padding-top: 12px; padding-left: 24px; padding-right: 24px; padding-bottom: 24px;
                        spacing: 24px;
                        
                        header-ref := Header {}
    
                        // ── Content Area ──
                        Rectangle {
                            horizontal-stretch: 1; vertical-stretch: 1;
    
                            // ── Songs View ──
                            if (AppState.active-nav-index == 0) : SongListView {}
    
                            // ── Library Views (Artists, Albums, Playlists, Settings) ──
                            if (AppState.active-nav-index != 0) : Rectangle {
                                TouchArea {
                                    scroll-event(event) => {
                                        AppState.add-wheel-velocity(event.delta-y / 1px);
                                        return accept;
                                    }
                                }
                                ScrollView {
                                    viewport-y <=> AppState.viewport-y-manual;
                                    horizontal-stretch: 1; vertical-stretch: 1;
                                    changed viewport-y => { AppState.song-grid-viewport-changed(self.viewport-y / 1px, self.height / 1px); }
                                    changed visible-height => {
                                        AppState.song-grid-viewport-changed(self.viewport-y / 1px, self.height / 1px);
                                        AppState.grid-visible-height = self.visible-height;
                                    }
                                    
                                    VerticalLayout {
                                        if (AppState.active-nav-index == 1 || AppState.active-nav-index == 2) : GridViews {}
                                        if (AppState.active-nav-index == 3) : PlaylistsView {}
                                        if (AppState.active-nav-index == 4) : SettingsView {}
                                    }
                                }
                            }
                        }
                        
                        if AppState.bottom-player-mode : BottomPlayer {}
                    }
                }
    
                if AppState.queue-visible : QueuePanel {}
    
                if !AppState.bottom-player-mode : PlayerBar {}
            }
        }

        if AppState.full-player-visible : FullPlayerOverlay {}

        key-pressed(event) => {
            if (event.modifiers.control && (event.text == "k" || event.text == "K" || event.text == "f" || event.text == "F")) {
                AppState.full-player-visible = false;
                AppState.active-nav-index = 0;
                header-ref.focus-search-bar();
                return accept;
            }
            if AppState.search-focused { return reject; }
            if event.text == Key.F11 { AppState.toggle-fullscreen(); return accept; }
            if event.text == " " { AppState.toggle-play-pause(); return accept; }
            return reject;
        }
    }

    init => { focus-scope.focus(); }
}
