export component QueueItemCard inherits Rectangle {
    in property <string> title;
    in property <string> artist;

    height: 56px;
    background: #141414;
    border-radius: 8px;

    VerticalLayout {
        padding: 12px;
        Text { text: root.title; color: #ffffff; font-size: 14px; font-weight: 600; overflow: elide; }
        Text { text: root.artist; color: #888888; font-size: 12px; overflow: elide; }
    }
}
