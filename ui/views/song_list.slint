import { AppState } from "../global.slint";
import { ListView } from "std-widgets.slint";

export component SongListView inherits Rectangle {
                            TouchArea {
                                scroll-event(event) => {
                                    AppState.add-wheel-velocity(event.delta-y / 1px);
                                    return accept;
                                }
                            }
                            VerticalLayout {
                                spacing: 0px;
                                Rectangle {
                                    height: 36px;
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 12px;
                                        spacing: 12px;
                                        Rectangle { width: 26px; } // Spacer for image align
                                        Text { text: "Title"; color: #888888; font-size: 12px; font-weight: 600; letter-spacing: 0.5px; width: 36%; vertical-alignment: center; overflow: elide; }
                                        Text { text: "Artist"; color: #888888; font-size: 12px; font-weight: 600; letter-spacing: 0.5px; width: 24%; vertical-alignment: center; overflow: elide; }
                                        Text { text: "Album"; color: #888888; font-size: 12px; font-weight: 600; letter-spacing: 0.5px; width: 22%; vertical-alignment: center; overflow: elide; }
                                        Text { text: "Duration"; color: #888888; font-size: 12px; font-weight: 600; letter-spacing: 0.5px; width: 60px; horizontal-alignment: right; vertical-alignment: center; overflow: elide; }
                                    }
                                    Rectangle { y: parent.height - 1px; height: 1px; background: #1a1a1a; }
                                }
                                song_list_view := ListView {
                                    viewport-y: AppState.viewport-y-manual-songs;
                                    changed viewport-y => {
                                        AppState.viewport-y-manual-songs = self.viewport-y;
                                        AppState.song-grid-viewport-changed(self.viewport-y / 1px, self.height / 1px);
                                    }
                                    changed visible-height => {
                                        AppState.song-grid-viewport-changed(self.viewport-y / 1px, self.height / 1px);
                                        AppState.song-list-visible-height = self.visible-height;
                                    }
                                    for row in AppState.song-rows : Rectangle {
                                        height: 36px;
                                        border-radius: 6px;
                                        background: row.songs[0].is_playing ? #ffffff10 : (song_touch.has-hover ? #ffffff08 : #00000000);
                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 12px;
                                            spacing: 12px;
                                            
                                            // ── Thumbnail ──
                                            Rectangle {
                                                width: 28px; height: 28px;
                                                border-radius: 4px;
                                                clip: true;
                                                background: #1a1a1a;
                                                Image {
                                                    source: row.songs[0].artwork;
                                                    width: 100%; height: 100%;
                                                    image-fit: cover;
                                                }
                                            }

                                            Text { text: row.songs[0].title; color: row.songs[0].is_playing ? #ffffff : #e8e8e8; font-size: 13px; font-weight: row.songs[0].is_playing ? 600 : 400; overflow: elide; width: 36%; vertical-alignment: center; }
                                            Text { text: row.songs[0].artist; color: row.songs[0].is_playing ? #cccccc : #999999; font-size: 13px; overflow: elide; width: 24%; vertical-alignment: center; }
                                            Text { text: row.songs[0].album; color: row.songs[0].is_playing ? #aaaaaa : #777777; font-size: 13px; overflow: elide; width: 22%; vertical-alignment: center; }
                                            Text { text: row.songs[0].duration; color: row.songs[0].is_playing ? #aaaaaa : #777777; font-size: 12px; width: 60px; horizontal-alignment: right; vertical-alignment: center; overflow: elide; }
                                        }
                                        song_touch := TouchArea {
                                            clicked => { AppState.play-song(row.songs[0].master_idx); }
                                            pointer-event(event) => {
                                                if (event.button == PointerEventButton.right && event.kind == PointerEventKind.up) {
                                                    AppState.enqueue-song(row.songs[0].master_idx);
                                                }
                                            }
                                        }
                                    }
                                }
                            }
}
