import { ScrollView } from "std-widgets.slint";
import { AppState } from "../global.slint";
import { IconButton, LucideIcon, WaveformSeekbar } from "../components/common.slint";

export component FullPlayerOverlay inherits Rectangle {
    width: 100%; height: 100%; background: #111111;
    
    // Logic properties
    property <int> active-index: AppState.active-lyrics-index;
    property <length> lyrics-target-y: 0px;
    property <length> scroll-accumulator: 0px;
    // PURE SYMMETRY: Both Art and Lyrics now anchor to this exact vertical offset
    property <length> billboard-y: 60px; 
    property <bool> swipe-locked: false;
    property <bool> manual-scroll-active: false;
    property <int> manual-scroll-reset-ticks: 0;

    // --- Background Layer ---
    Rectangle {
        width: 100%; height: 100%;
        Image { 
            source: AppState.now-artwork-blurred; width: 100%; height: 100%; image-fit: cover; 
            opacity: AppState.blur-enabled ? 0.75 : 0.0; 
        }
        Image { 
            source: AppState.now-artwork-blurred; width: 100%; height: 100%; image-fit: cover; 
            opacity: AppState.blur-enabled ? 0.85 : 0.0; 
        }
        // Stronger dark overlay to ensure white text/icons are ALWAYS legible against pure white album art
        Rectangle { width: 100%; height: 100%; background: AppState.blur-enabled ? #0000007a : #0a0a0af0; }
        
        TouchArea {
            width: 100%; height: 100%;
            scroll-event(evt) => {
                if (abs(evt.delta-x / 1px) > 2.5) {
                    root.scroll-accumulator += evt.delta-x;
                    if (abs(root.scroll-accumulator / 1px) > 350.0 && !root.swipe-locked) {
                        if (root.scroll-accumulator > 0px) { AppState.previous-song(); } else { AppState.next-song(); }
                        root.scroll-accumulator = 0px;
                        root.swipe-locked = true; // LOCK SENSITIVITY
                    }
                    return EventResult.accept;
                }
                // RESET LOCK when swipe stops or reverses
                if (abs(evt.delta-x / 1px) < 0.5) {
                    root.swipe-locked = false;
                    root.scroll-accumulator = 0px;
                }
                return EventResult.reject;
            }
        }
    }

    // --- Content Layer ---
    VerticalLayout {
        padding: 40px; spacing: 0px; width: 100%;
        
        // Header
        HorizontalLayout {
            height: 48px;
            IconButton { icon: AppState.icon-chevron-left; clicked => { AppState.full-player-visible = false; } }
            Rectangle { horizontal-stretch: 1; }
        }
        // --- Main Switcher Section ---
        Rectangle {
            vertical-stretch: 1; width: 100%;
            
            // DYNAMIC LAYOUT ENGINE
            // We calculate the positions manually to ensure 100% responsiveness and zero-jitter transitions.
            property <length> art-width: 600px; // Optimized for long song titles
            property <length> lyrics-width: root.width - art-width - 180px; 
            
            // X-Coordinates for Animated Symmetry
            property <length> art-center-x: (parent.width - art-width) / 2;
            property <length> art-billboard-x: 60px;
            property <length> target-art-x: AppState.full-player-lyrics-visible ? art-billboard-x : art-center-x;
            
            animate target-art-x { duration: 550ms; easing: cubic-bezier(0.16, 1, 0.3, 1); }

            // Fixed Vertical Anchor (The Skyline Floor)
            property <length> skyline-y: 32px;

            VerticalLayout {
                x: parent.target-art-x;
                y: skyline-y;
                width: art-width; spacing: 20px;
                alignment: start;
                
                // Artwork Billboard (380x380)
                HorizontalLayout {
                    alignment: start; 
                    padding-left: (art-width - 380px) / 2;
                    Rectangle {
                        width: 380px; height: 380px; border-radius: 14px;
                        clip: true; background: #22222260;
                        Image { source: AppState.now-artwork; width: 100%; height: 100%; image-fit: cover; }
                        
                        // Subtle Inner Glow
                        Rectangle { width: 100%; height: 100%; border-width: 1px; border-color: #ffffff0a; border-radius: 14px; }
                    }
                }

                // Metadata Stack (Centered and Symmetrical)
                VerticalLayout {
                    spacing: 6px; width: art-width;
                    Text { 
                        text: AppState.now-title; color: #ffffff; font-size: 32px; font-weight: 800; 
                        horizontal-alignment: center; overflow: elide;
                    }
                    HorizontalLayout {
                        spacing: 12px; alignment: center;
                        Text { 
                            text: AppState.now-artist; color: #ffffff; opacity: 0.7; font-size: 17px; font-weight: 600; 
                            horizontal-alignment: center; letter-spacing: 0.3px; 
                        }
                    }
                }

                // Seekbar (Symmetrical)
                VerticalLayout {
                    width: 380px; spacing: 8px; x: (art-width - 380px) / 2;
                    
                    if AppState.waveform-seekbar-enabled : WaveformSeekbar {
                        height: 48px;
                        progress: AppState.progress-slider-value;
                        seek(ratio) => { AppState.seek-to-ratio(ratio); }
                    }

                    if !AppState.waveform-seekbar-enabled : Rectangle {
                        height: 24px;
                        Rectangle { 
                            y: 10px; height: 5px; background: #ffffff12; border-radius: 2.5px;
                            Rectangle { x: 0; width: parent.width * AppState.progress-slider-value; background: AppState.accent-color; border-radius: 2.5px; animate background { duration: 400ms; } }
                        }
                        TouchArea { clicked => { AppState.seek-to-ratio(self.mouse-x / self.width); } }
                    }
                    HorizontalLayout {
                        Text { text: AppState.progress-current; color: #ffffff; opacity: 0.45; font-size: 11px; font-weight: 700; }
                        Rectangle { horizontal-stretch: 1; }
                        Text { text: AppState.progress-total; color: #ffffff; opacity: 0.45; font-size: 11px; font-weight: 700; }
                    }
                }

                // Controls (Centered Gutter)
                HorizontalLayout {
                    spacing: 34px; height: 80px; alignment: center;
                    width: art-width;
                    
                    // Shuffle with glow
                    Rectangle {
                        width: 32px; height: 32px; y: (parent.height - self.height) / 2;
                        background: #00000020; border-radius: 16px;
                        IconButton { width: 100%; height: 100%; icon: AppState.icon-shuffle; clicked => { AppState.toggle-shuffle(); } }
                    }

                    // Prev with glow
                    Rectangle {
                        width: 52px; height: 52px; y: (parent.height - self.height) / 2;
                        background: #00000015; border-radius: 26px;
                        IconButton { width: 100%; height: 100%; icon: AppState.icon-skip-back; clicked => { AppState.previous-song(); } }
                    }

                    // Play/Pause
                    Rectangle {
                        width: 72px; height: 72px; border-radius: 36px; background: AppState.accent-color;
                        animate background { duration: 400ms; }
                        LucideIcon { icon: AppState.is-playing ? AppState.icon-pause : AppState.icon-play; icon-color: #000000; width: 32px; height: 32px; x: (parent.width - self.width) / 2 + (AppState.is-playing ? 0px : 3px); y: (parent.height - self.height) / 2; }
                        TouchArea { clicked => { AppState.toggle-play-pause(); } }
                    }

                    // Next with glow
                    Rectangle {
                        width: 52px; height: 52px; y: (parent.height - self.height) / 2;
                        background: #00000015; border-radius: 26px;
                        IconButton { width: 100%; height: 100%; icon: AppState.icon-skip-forward; clicked => { AppState.next-song(); } }
                    }

                    // Repeat with glow
                    Rectangle {
                        width: 32px; height: 32px; y: (parent.height - self.height) / 2;
                        background: #00000020; border-radius: 16px;
                        IconButton { width: 100%; height: 100%; icon: AppState.icon-repeat; clicked => { AppState.cycle-repeat(); } }
                    }
                }
            }

            // --- Lyrics Layer ---
            if (AppState.full-player-lyrics-visible) : Rectangle {
                x: art-width + 100px;
                y: skyline-y;
                width: lyrics-width;
                height: parent.height - skyline-y - 40px;
                opacity: 0.0;
                clip: true;

                animate opacity { duration: 800ms; easing: ease-out; }

                lyrics-scroll := ScrollView {
                    width: 100%; height: 100%;
                    vertical-scrollbar-policy: always-off;
                    viewport-y <=> root.lyrics-target-y;

                    property <int> local-active-index: root.active-index;
                    changed local-active-index => {
                        if (!root.manual-scroll-active) {
                            root.lyrics-target-y = -(self.local-active-index * 76) * 1px;
                        } else {
                            root.manual-scroll-active = false;
                            root.lyrics-target-y = -(self.local-active-index * 76) * 1px;
                        }
                    }
                    
                    animate viewport-y { duration: 1200ms; easing: cubic-bezier(0.16, 1, 0.3, 1); }
                    
                    VerticalLayout {
                        padding-right: 40px; // SAFE GUTTER FOR WRAPPING
                        padding-bottom: parent.height / 2;
                        spacing: 0px; 
                        
                        if AppState.lyric-lines.length > 0 : VerticalLayout {
                            for line[idx] in AppState.lyric-lines : Rectangle {
                                height: 76px;
                                Text {
                                    text: line; wrap: word-wrap;
                                    color: (idx == AppState.active-lyrics-index) ? #ffffff : #ffffff33;
                                    font-size: 32px;
                                    font-weight: (idx == AppState.active-lyrics-index) ? 800 : 700;
                                    horizontal-alignment: left; width: parent.width; vertical-alignment: center;
                                    animate color { duration: 550ms; }
                                }
                                line-touch := TouchArea {
                                    clicked => { AppState.seek-to-lyric-index(idx); }
                                    mouse-cursor: pointer;
                                    
                                    // Manual scroll detection per line to prevent stealing clicks
                                    pointer-event(evt) => {
                                        if (evt.kind == PointerEventKind.down) { root.manual-scroll-active = true; }
                                    }
                                    scroll-event(evt) => {
                                        root.manual-scroll-active = true;
                                        root.lyrics-target-y += evt.delta-y;
                                        return EventResult.reject; 
                                    }
                                }
                                // Hover effect
                                Rectangle {
                                    width: parent.width; height: parent.height;
                                    background: #ffffff;
                                    opacity: line-touch.has-hover ? 0.05 : 0.0;
                                    border-radius: 8px;
                                }
                            }
                        }
                        if (AppState.lyric-lines.length == 0) : VerticalLayout {
                            padding-top: 40px;
                            Text { 
                                text: AppState.lyrics-text; color: #ffffff; font-size: 32px; 
                                font-weight: 700; wrap: word-wrap; horizontal-alignment: left; 
                            }
                        }
                    }
                }
                
                // Manual Scroll Detection for empty areas
                TouchArea {
                    width: 100%; height: 100%;
                    // Put it in background so it doesn't block line clicks
                    z: -1;
                    scroll-event(evt) => {
                        root.manual-scroll-active = true;
                        root.lyrics-target-y += evt.delta-y;
                        return EventResult.reject; 
                    }
                    pointer-event(evt) => {
                        if (evt.kind == PointerEventKind.down) { root.manual-scroll-active = true; }
                    }
                }
                
                init => { self.opacity = 1.0; }
            }
        }

        // Footer
        HorizontalLayout {
            height: 44px;
            
            Rectangle { horizontal-stretch: 1; }
            
            // Bottom Right Lyrics Toggle
            VerticalLayout {
                alignment: end;
                Rectangle {
                    width: 44px; height: 44px; border-radius: 12px;
                    background: AppState.full-player-lyrics-visible ? #ffffff25 : #ffffff10;
                    LucideIcon { icon: AppState.icon-list-music; icon-color: #ffffff; width: 20px; height: 20px; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
                    TouchArea { clicked => { AppState.full-player-lyrics-visible = !AppState.full-player-lyrics-visible; } }
                }
            }
        }
    }

    // --- Absolute Bottom Left Quality Indicator ---
    if (AppState.now-playing-quality != "") : Rectangle {
        x: 24px;
        y: parent.height - 32px;
        width: 200px;
        height: 20px;
        Text { 
            text: AppState.now-playing-quality; 
            color: #ffffff; opacity: 0.35; font-size: 10px; font-weight: 800; 
            letter-spacing: 1px;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
    }
}
