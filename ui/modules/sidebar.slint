import { AppState } from "../global.slint";
import { SidebarItem } from "../components/common.slint";

export component Sidebar inherits Rectangle {
    width: 180px;
    background: #ffffff05;
    border-width: 1px;
    border-color: #ffffff10;
    VerticalLayout {
        padding: 16px; spacing: 4px;
        
        // ── Branding ──
        if (AppState.active-nav-index != 4) : VerticalLayout {
            padding-bottom: 24px;
            HorizontalLayout {
                spacing: 12px;
                alignment: start;
                Rectangle {
                    width: 24px; height: 24px;
                    Image {
                        source: AppState.branding-logo;
                        width: 100%; height: 100%;
                        image-fit: contain;
                        colorize: #ffffff;
                    }
                }
                Text {
                    text: "Orca";
                    color: #ffffff;
                    font-size: 18px;
                    font-weight: 800;
                    vertical-alignment: center;
                    letter-spacing: -0.2px;
                }
            }
        }
        SidebarItem { icon: AppState.icon-music; text: "Songs"; active: AppState.active-nav-index == 0; clicked => { AppState.active-nav-index = 0; } }
        SidebarItem { icon: AppState.icon-users; text: "Artists"; active: AppState.active-nav-index == 1; clicked => { AppState.active-nav-index = 1; } }
        SidebarItem { icon: AppState.icon-disc-3; text: "Albums"; active: AppState.active-nav-index == 2; clicked => { AppState.active-nav-index = 2; } }
        SidebarItem { icon: AppState.icon-list-music; text: "Playlists"; active: AppState.active-nav-index == 3; clicked => { AppState.active-nav-index = 3; } }
        SidebarItem { icon: AppState.icon-settings; text: "Settings"; active: AppState.active-nav-index == 4; clicked => { AppState.active-nav-index = 4; } }
        Rectangle { vertical-stretch: 1; }
        SidebarItem { icon: AppState.icon-folder-plus; text: "Add Folder"; clicked => { AppState.add-folder(); } }
        SidebarItem { icon: AppState.icon-refresh-cw; text: "Refresh"; clicked => { AppState.scan_saved_roots(); } }
    }
}
