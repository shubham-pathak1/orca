{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orca",
  "version": "0.1.3",
  "identifier": "dev.orca.player",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "plugins": {
    "taskbar": {
      "autoAttach": true,
      "windowLabel": "main",
      "icons": {
        "previous": "icons/taskbar/PREV_THUMB.ico",
        "previousDisabled": "icons/taskbar/PREV_THUMB_DISABLED.ico",
        "play": "icons/taskbar/PLAY_THUMB.ico",
        "pause": "icons/taskbar/PAUSE_THUMB.ico",
        "next": "icons/taskbar/NEXT_THUMB.ico",
        "nextDisabled": "icons/taskbar/NEXT_THUMB_DISABLED.ico"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Orca",
        "width": 1280,
        "height": 820,
        "minWidth": 500,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$LOCALDATA/**", "$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["icons/taskbar/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
